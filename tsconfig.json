{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "types": ["node", "vscode"]
  },
  "include": ["./*.ts"],
  "exclude": ["node_modules", "dist"]
}
